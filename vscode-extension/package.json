{
  "name": "clarity-agent",
  "displayName": "Clarity Agent",
  "description": "Structured thinking about what you're building, why, and what could go wrong — powered by LLMs.",
  "version": "0.1.1",
  "publisher": "clarity-agent",
  "icon": "media/icon.png",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "https://github.com/microsoft/clarity-agent"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "clarity",
    "protocol",
    "structured-thinking",
    "failure-analysis",
    "architecture"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "extensionDependencies": [],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "clarity-sidebar",
          "title": "Clarity Agent",
          "icon": "media/clarity-icon.svg"
        }
      ]
    },
    "views": {
      "clarity-sidebar": [
        {
          "type": "webview",
          "id": "clarity.sidebarView",
          "name": "Chat"
        },
        {
          "id": "clarity.protocolTree",
          "name": "Protocol Documents"
        }
      ]
    },
    "commands": [
      {
        "command": "clarity.switchProject",
        "title": "Clarity: Switch Project"
      },
      {
        "command": "clarity.setup",
        "title": "Clarity: Run Setup Wizard"
      },
      {
        "command": "clarity.selectModel",
        "title": "Clarity: Select Model"
      },
      {
        "command": "clarity.generatePacket",
        "title": "Clarity: Generate Packet"
      },
      {
        "command": "clarity.listProcesses",
        "title": "Clarity: List Processes"
      },
      {
        "command": "clarity.viewTranscripts",
        "title": "Clarity: View Transcripts"
      },
      {
        "command": "clarity.sendFeedback",
        "title": "Clarity: Send Feedback"
      },
      {
        "command": "clarity.configureMcp",
        "title": "Clarity: Configure MCP Server"
      },
      {
        "command": "clarity.refreshProtocol",
        "title": "Clarity: Refresh Protocol Tree",
        "icon": "$(refresh)"
      },
      {
        "command": "clarity.open",
        "title": "Clarity: Open"
      },
      {
        "command": "clarity.openProject",
        "title": "Clarity: Open Project..."
      },
      {
        "command": "clarity.doctor",
        "title": "Clarity: Doctor (Diagnose Installation)"
      },
      {
        "command": "clarity.restart",
        "title": "Clarity: Restart Backend"
      }
    ],
    "configuration": {
      "title": "Clarity Agent",
      "properties": {
        "clarity.pythonPath": {
          "type": "string",
          "default": "",
          "description": "Path to the Python interpreter. Leave empty to use 'python3' or 'python' from PATH."
        },
        "clarity.agentDir": {
          "type": "string",
          "default": "",
          "description": "Path to the clarity-agent repository. Leave empty to auto-detect (assumes the extension is installed from within the repo)."
        },
        "clarity.port": {
          "type": "number",
          "default": 0,
          "description": "Port for the Clarity backend server. Set to 0 for automatic (ephemeral) port selection."
        },
        "clarity.useUv": {
          "type": "boolean",
          "default": true,
          "description": "Use 'uv' for dependency management if available. Falls back to pip when uv is not found."
        },
        "clarity.provider": {
          "type": "string",
          "default": "",
          "enum": [
            "",
            "anthropic",
            "openai",
            "azure",
            "azure-openai",
            "claude-sdk",
            "google",
            "github-copilot"
          ],
          "description": "LLM provider to use. Leave empty to use the default from .env."
        },
        "clarity.model": {
          "type": "string",
          "default": "",
          "description": "LLM model name override. Leave empty to use the provider default."
        }
      }
    },
    "menus": {
      "view/title": [
        {
          "command": "clarity.refreshProtocol",
          "when": "view == clarity.protocolTree",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "bundle": "node bundle.js",
    "test": "node esbuild.js && node out/test/runTest.js",
    "package": "npm run bundle && npx @vscode/vsce package --allow-missing-repository",
    "vscode:prepublish": "node bundle.js && node esbuild.js --production"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.4",
    "glob": "^13.0.6",
    "mocha": "^11.3.0",
    "typescript": "^5.6.0"
  }
}
